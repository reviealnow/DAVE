# Copy this file to .env and fill in values.
# .env is auto-created on first startup with a generated AUTH_SECRET_KEY.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generated automatically on first run. Set manually for production.
AUTH_SECRET_KEY=

# Token lifetime in minutes (default 480 = 8 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=480

# Set to true when running behind HTTPS (e.g. Caddy / Nginx TLS)
# SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SAMESITE=lax

# ── App mode ──────────────────────────────────────────────────────────────────
# desktop : Tauri shell, listens on 127.0.0.1
# server  : LAN / Pi web service, listens on 0.0.0.0
# APP_MODE=server
# APP_HOST=0.0.0.0
# APP_PORT=8765

# ── File share ────────────────────────────────────────────────────────────────
# FILESHARE_MAX_UPLOAD_MB=50
# FILESHARE_UPLOAD_DIR=./data/fileshare/uploads
# FILESHARE_DB_PATH=./data/fileshare/fileshare.db
