{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devPath": "http://127.0.0.1:5173",
    "distDir": "../../frontend/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "DAVE",
    "version": "0.1.3"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "windows": [
      {
        "title": "DAVE Lab Portal",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.reviealnow.dave",
      "publisher": "reviealnow",
      "category": "DeveloperTool",
      "shortDescription": "DAVE Lab Portal",
      "longDescription": "DAVE Lab Portal — DUT dashboard + lab file sharing, packaged as a desktop app.",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [],
      "resources": [],
      "copyright": "",
      "macOS": {
        "minimumSystemVersion": "10.15"
      }
    }
  }
}
